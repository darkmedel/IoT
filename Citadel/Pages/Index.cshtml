@page
@model IndexModel
@{
    ViewData["Title"] = "Citadel";
}

<div class="container-fluid px-4 py-4">
    <h2 class="mb-3">Dispositivos</h2>

    <div class="mb-3 d-flex gap-2">
        <input id="txtFiltro" class="form-control w-25" placeholder="Buscar..." />
        <button class="btn btn-primary" onclick="cargar()">Refrescar</button>
        <button class="btn btn-success" onclick="abrirModalDevice()">Nuevo Device</button>
        <button class="btn btn-secondary" onclick="abrirModalEmpresa()">Nueva Empresa</button>
    </div>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>DeviceId</th>
                <th>Firmware</th>
                <th>Empresa</th>
                <th>Nombre</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="tbl"></tbody>
    </table>
</div>

@section Scripts{
<script src="/js/app.js"></script>
}
