@page
@model cl.MedelCodeFactory.IoT.Citadel.Pages.IndexModel

<div class="container-fluid px-4 py-4">
    <section class="card-panel mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-lg-5">
                <label for="txtSearch" class="form-label">Buscar</label>
                <div class="input-group">
                    <span class="input-group-text bg-panel-2 text-muted border-secondary-subtle"><i class="bi bi-search"></i></span>
                    <input id="txtSearch" type="text" class="form-control form-control-dark" placeholder="Buscar por device, firmware, empresa o nombre..." />
                </div>
            </div>
            <div class="col-12 col-lg-auto">
                <button id="btnRefresh" class="btn btn-outline-light w-100"><i class="bi bi-arrow-clockwise me-1"></i> Refrescar</button>
            </div>
            <div class="col-12 col-lg-auto">
                <button id="btnNewDevice" class="btn btn-primary w-100"><i class="bi bi-cpu me-1"></i> Nuevo dispositivo</button>
            </div>
            <div class="col-12 col-lg-auto">
                <button id="btnManageCompanies" class="btn btn-secondary w-100"><i class="bi bi-buildings me-1"></i> Empresas</button>
            </div>
        </div>
    </section>

    <section class="card-panel">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <h2 class="section-title mb-1">Dispositivos</h2>
                <div class="section-subtitle">Vista operacional con asignación y acciones.</div>
            </div>
            <div class="small text-muted"><span id="deviceCount">0</span> registros</div>
        </div>

        <div class="table-responsive">
            <table class="table table-dark align-middle compact-table mb-0">
                <thead>
                    <tr>
                        <th>DeviceId</th>
                        <th>Tipo HW</th>
                        <th>Firmware</th>
                        <th>Empresa</th>
                        <th>Nombre dispositivo</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="devicesBody">
                    <tr><td colspan="7" class="text-center py-5 text-muted">Cargando...</td></tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<div class="modal fade" id="deviceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header border-secondary-subtle">
                <h5 class="modal-title" id="deviceModalTitle">Nuevo dispositivo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form novalidate>
                    <input type="hidden" id="deviceFormMode" value="create" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">DeviceId</label>
                            <input type="text" id="deviceId" class="form-control form-control-dark text-uppercase" maxlength="12" />
                            <div class="form-hint">12 caracteres hexadecimales. Ej.: 808A26A50528</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">TipoHardware</label>
                            <select id="tipoHardwareId" class="form-select form-select-dark"></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Firmware</label>
                            <select id="firmwareId" class="form-select form-select-dark"></select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">FirmwareVersion</label>
                            <input type="text" id="firmwareVersion" class="form-control form-control-dark" maxlength="50" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="deviceEnabled" checked>
                                <label class="form-check-label" for="deviceEnabled">Habilitado</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary-subtle">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnSaveDevice" class="btn btn-primary"><span class="label">Guardar</span></button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header border-secondary-subtle">
                <h5 class="modal-title">Asignar dispositivo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form novalidate>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">DeviceId</label>
                            <input type="text" id="assignDeviceId" class="form-control form-control-dark" readonly />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Empresa</label>
                            <select id="assignEmpresaId" class="form-select form-select-dark"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nombre dispositivo</label>
                            <input type="text" id="assignNombreDispositivo" class="form-control form-control-dark" maxlength="200" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Descripción</label>
                            <input type="text" id="assignDescripcion" class="form-control form-control-dark" maxlength="500" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary-subtle">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnSaveAssignment" class="btn btn-success">Asignar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="unassignModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header border-secondary-subtle">
                <h5 class="modal-title">Confirmar desasignación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Se desasignará el dispositivo <strong id="unassignDeviceIdText"></strong>.</p>
                <div class="form-group">
                    <label class="form-label">Usuario</label>
                    <input type="text" id="unassignUser" class="form-control form-control-dark" maxlength="100" value="web" />
                </div>
            </div>
            <div class="modal-footer border-secondary-subtle">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmUnassign" class="btn btn-danger">Desasignar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="companiesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header border-secondary-subtle">
                <h5 class="modal-title">Empresas</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-end mb-3">
                    <button type="button" id="btnNewCompany" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Nueva empresa</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark align-middle compact-table mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th>Habilitado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="companiesBody">
                            <tr><td colspan="5" class="text-center py-4 text-muted">Cargando...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="companyFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header border-secondary-subtle">
                <h5 class="modal-title" id="companyModalTitle">Nueva empresa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form novalidate>
                    <input type="hidden" id="companyFormMode" value="create" />
                    <input type="hidden" id="companyId" value="" />
                    <div class="mb-3">
                        <label class="form-label">Código</label>
                        <input type="text" id="companyCodigo" class="form-control form-control-dark text-uppercase" maxlength="50" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" id="companyNombre" class="form-control form-control-dark" maxlength="200" />
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="companyEnabled" checked>
                        <label class="form-check-label" for="companyEnabled">Habilitada</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary-subtle">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnSaveCompany" class="btn btn-primary">Guardar</button>
            </div>
        </div>
    </div>
</div>
